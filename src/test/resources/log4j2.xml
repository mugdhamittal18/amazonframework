<?xml version="1.0" encoding="UTF-8"?>

<Configuration>

    <Appenders>

        <File name="FileLogger"
              fileName="logs/framework.log">

            <PatternLayout
                    pattern="%d %p %c %m%n"/>

        </File>

    </Appenders>

    <Loggers>

        <Root level="info">

            <AppenderRef ref="FileLogger"/>

        </Root>

    </Loggers>

</Configuration>